# IdeaSync Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Database Configuration
DB_HOST=localhost
DB_NAME=ideaspace_prod
DB_USER=ideaspace_user
DB_PASSWORD=your_very_secure_password_here_min_16_chars
DB_PORT=3306

# Application Configuration
APP_ENV=production
APP_DEBUG=false
APP_URL=https://ideasync.yourdomain.com
APP_KEY=your_app_key_here_random_32_chars_min

# Email Configuration
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASSWORD=your_sendgrid_api_key_here
EMAIL_FROM=noreply@ideasync.yourdomain.com
EMAIL_NAME=IdeaSync

# Session Configuration
SESSION_TIMEOUT=3600
SESSION_SECURE=true
SESSION_HTTPONLY=true

# Security Configuration
CSRF_TOKEN_LIFETIME=3600
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW=3600
RATE_LIMIT_PASSWORD_ATTEMPTS=3
RATE_LIMIT_PASSWORD_WINDOW=3600

# File Upload Configuration
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=uploads/
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,jpg,jpeg,png,gif,zip

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://ideasync.yourdomain.com/?page=auth&action=github-callback

# Logging
LOG_LEVEL=error
LOG_FILE=logs/app.log
SECURITY_LOG_FILE=logs/security.log

# Cache Configuration (for future use)
CACHE_DRIVER=file
CACHE_TTL=3600
