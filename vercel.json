{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "public/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "rewrites": [
    {
      "source": "/(css|js|img|assets)/(.*)",
      "destination": "/public/$1/$2"
    },
    {
      "source": "/(.*)\\.(php|html)",
      "destination": "/public/$1.$2"
    },
    {
      "source": "/(.*)",
      "destination": "/public/index.php"
    }
  ]
}
