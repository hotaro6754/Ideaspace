{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "./Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "apache2-foreground",
    "healthcheckPath": "/",
    "healthcheckInterval": 10,
    "memoryMB": 512,
    "cpuNumber": 0.5
  },
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "PORT": "80"
  }
}
